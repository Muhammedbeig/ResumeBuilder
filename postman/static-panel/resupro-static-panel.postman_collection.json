          }
        },
        {
          "name": "Stripe Portal",
          "request": {
            "method": "GET",
            "url": "{{apiBaseUrl}}/stripe/portal?returnUrl=%2Fdashboard"
          }
        },
        {
          "name": "Stripe Return",
          "request": {
            "method": "GET",
            "url": "{{apiBaseUrl}}/stripe/return?stripe=success&payment_transaction_id={{paymentTransactionId}}&session_id={{stripeSessionId}}&return_url=%2Fpricing"
          },
          "protocolProfileBehavior": {
            "followRedirects": false
          }
        },
        {
          "name": "Stripe Webhook (Signature Required)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "stripe-signature",
                "value": "{{stripeSignature}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{stripeWebhookPayload}}"
            },
            "url": "{{apiBaseUrl}}/stripe/webhook"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const payload = pm.environment.get('stripeWebhookPayload') || '{}';",
                  "const secret = pm.environment.get('stripeWebhookSecret') || '';",
                  "if (!secret) {",
                  "  console.warn('stripeWebhookSecret is empty');",
                  "} else {",
                  "  const timestamp = Math.floor(Date.now() / 1000);",
                  "  const signedPayload = `${timestamp}.${payload}`;",
                  "  const signature = CryptoJS.HmacSHA256(signedPayload, secret).toString(CryptoJS.enc.Hex);",
                  "  pm.environment.set('stripeSignature', `t=${timestamp},v1=${signature}`);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "PayPal Checkout",
          "request": {
            "method": "POST",
            "header": [
