RewriteEngine On

# Serve existing files and folders directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ------------------------------------------------------------
# API forwarding (required for static export deployments)
# ------------------------------------------------------------
# OPTION A: If Apache proxy modules are enabled, uncomment and
# set your Panel base domain. Keep the /api suffix.
#
# RewriteRule ^api/(.*)$ https://panel.example.com/api/$1 [P,L,QSA,NE]
#
# OPTION B: If your Panel API is available under the same host
# in a sub-path, rewrite internally instead of proxying.
#
# RewriteRule ^api/(.*)$ /panel/api/$1 [L,QSA,NE]

# ------------------------------------------------------------
# Dynamic app route placeholders generated by Next export
# ------------------------------------------------------------
RewriteRule ^resume/(new|start)/?$ - [L,NC]
RewriteRule ^resume/[^/]+/?$ /resume/_.html [L,NC,QSA]

RewriteRule ^cv/(new|start)/?$ - [L,NC]
RewriteRule ^cv/[^/]+/?$ /cv/_.html [L,NC,QSA]

RewriteRule ^cover-letter/(new|start|templates)/?$ - [L,NC]
RewriteRule ^cover-letter/[^/]+/?$ /cover-letter/_.html [L,NC,QSA]

RewriteRule ^reports/[^/]+/?$ /reports/_.html [L,NC,QSA]
RewriteRule ^shared/[^/]+/?$ /shared/_.html [L,NC,QSA]

RewriteRule ^career-blog/category/[^/]+/?$ /career-blog/category/_.html [L,NC,QSA]
RewriteRule ^career-blog/tag/[^/]+/?$ /career-blog/tag/_.html [L,NC,QSA]
RewriteCond %{REQUEST_URI} !^/career-blog/?$ [NC]
RewriteCond %{REQUEST_URI} !^/career-blog/(category|tag)/ [NC]
RewriteRule ^career-blog/[^/]+/?$ /career-blog/_.html [L,NC,QSA]

RewriteRule ^templates/[^/]+/?$ /templates/all.html [L,NC,QSA]

# ------------------------------------------------------------
# Static HTML fallback
# ------------------------------------------------------------
RewriteRule ^$ /index.html [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+?)/?$ /$1.html [L,NC,QSA]
